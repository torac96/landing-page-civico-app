---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<nav class="navbar">
  <div class="container">
    <a href={base} class="logo">
      <img src={`${base}assets/logo.png`} alt="Civico App" class="logo-img" width="44" height="44" />
      Civico App
    </a>
    <div class="nav-links">
      <a href={base}>Home</a>
      <a href={`${base}supporto`}>Supporto</a>
      <a href={`${base}privacy`}>Privacy</a>
    </div>
  </div>
</nav>
