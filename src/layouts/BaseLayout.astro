---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = '/assets/favicon.png' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageAbsolute = new URL(base.replace(/\/$/, '') + ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#5B8DEE" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:site_name" content="Civico App" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Fonts: self-hosted, preload critical -->
    <link rel="preload" href={`${base}fonts/dm-serif-display-normal.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}fonts/work-sans-400.woff2`} as="font" type="font/woff2" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="256x256" href={`${base}assets/favicon.png`} />

    <!-- Font face declarations with correct base path -->
    <style set:html={`
      @font-face {
        font-family: 'DM Serif Display';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('${base}fonts/dm-serif-display-normal.woff2') format('woff2');
      }
      @font-face {
        font-family: 'DM Serif Display';
        font-style: italic;
        font-weight: 400;
        font-display: swap;
        src: url('${base}fonts/dm-serif-display-italic.woff2') format('woff2');
      }
      @font-face {
        font-family: 'Work Sans';
        font-style: normal;
        font-weight: 400 600;
        font-display: swap;
        src: url('${base}fonts/work-sans-400.woff2') format('woff2');
      }
    `} />
  </head>
  <body>
    <slot />
    <script src="../scripts/main.ts"></script>
  </body>
</html>
