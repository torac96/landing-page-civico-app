---
import { Image } from 'astro:assets';
import logoSrc from '../assets/logo.png';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <a href={base} class="logo" style="margin-bottom: 0.75rem; display: inline-flex;">
          <Image src={logoSrc} alt="" class="logo-img" width={44} height={44} format="webp" quality={85} />
          Civico App
        </a>
        <p>Il tuo assistente per documenti e cittadinanza italiana.</p>
      </div>
      <div class="footer-section">
        <h4>Link Utili</h4>
        <ul>
          <li><a href={base}>Home</a></li>
          <li><a href={`${base}supporto`}>Supporto</a></li>
          <li><a href={`${base}privacy`}>Privacy Policy</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h4>Contatti</h4>
        <ul>
          <li><a href="mailto:support@civico-app.com">support@civico-app.com</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Civico App. Tutti i diritti riservati.</p>
    </div>
  </div>
</footer>
