---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FeatureCard from '../components/FeatureCard.astro';

const features = [
  {
    icon: '📋',
    title: 'Gestione Documenti',
    description: "Organizza passaporto, carta d'identità, patente e tutti i tuoi documenti in un unico posto. Non perdere mai una scadenza.",
  },
  {
    icon: '🔔',
    title: 'Notifiche Intelligenti',
    description: 'Ricevi promemoria automatici 30 giorni prima della scadenza. Pianifica i rinnovi con anticipo e senza stress.',
  },
  {
    icon: '🇮🇹',
    title: 'Guida Cittadinanza',
    description: 'Guide complete passo-passo per ottenere la cittadinanza italiana. Dalla richiesta al giuramento, ti accompagniamo in tutto il percorso.',
  },
  {
    icon: '🏛️',
    title: 'Servizi Comunali',
    description: 'Accedi rapidamente a informazioni su servizi municipali, anagrafe e pratiche amministrative.',
  },
  {
    icon: '🇷🇴',
    title: 'Supporto Multilingue',
    description: 'Disponibile in italiano e rumeno. Pensata per la comunità italiana e straniera in Italia.',
  },
  {
    icon: '🔒',
    title: 'Privacy Garantita',
    description: 'I tuoi dati restano sul tuo dispositivo. Nessuna raccolta di informazioni personali sensibili.',
  },
];

const appleSvg = `<svg width="20" height="24" viewBox="0 0 20 24" fill="none">
  <path d="M15.95 11.9C15.93 9.57 17.84 8.45 17.94 8.39C16.87 6.81 15.19 6.59 14.61 6.57C13.14 6.42 11.71 7.47 10.96 7.47C10.19 7.47 9.01 6.59 7.77 6.61C6.16 6.63 4.67 7.57 3.84 9.03C2.13 12.01 3.4 16.42 5.04 18.84C5.86 20.03 6.81 21.36 8.04 21.32C9.25 21.27 9.7 20.53 11.15 20.53C12.58 20.53 13 21.32 14.26 21.29C15.56 21.27 16.39 20.09 17.18 18.89C18.12 17.52 18.5 16.18 18.52 16.11C18.49 16.1 15.97 15.11 15.95 11.9Z" fill="currentColor"/>
  <path d="M13.36 4.83C14.03 4.02 14.5 2.91 14.37 1.79C13.43 1.83 12.27 2.43 11.58 3.23C10.96 3.93 10.39 5.07 10.54 6.16C11.6 6.25 12.68 5.64 13.36 4.83Z" fill="currentColor"/>
</svg>`;

const androidSvg = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
  <path d="M17.6 9.48l1.84-3.18c.16-.31.04-.69-.26-.85-.29-.15-.65-.06-.83.22l-1.88 3.24A9.82 9.82 0 0 0 12 8c-1.64 0-3.18.43-4.47 1.18L5.65 5.94a.64.64 0 0 0-.83-.22.64.64 0 0 0-.26.85l1.84 3.18C3.92 11.13 2.5 13.42 2.5 16h19c0-2.58-1.42-4.87-3.9-6.52zM9 13.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm6 0a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
</svg>`;
---

<BaseLayout
  title="Civico App - Il tuo hub per documenti e cittadinanza italiana"
  description="Gestisci documenti, scadenze e pratiche di cittadinanza. L'app essenziale per italiani e stranieri residenti in Italia."
>
  <Navbar />

  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1 class="hero-title">
          Il tuo hub per<br />
          <span class="highlight">documenti e cittadinanza</span><br />
          italiana
        </h1>
        <p class="hero-subtitle">
          Basta scadenze dimenticate e ricerche infinite sui siti comunali.
          Civico organizza i tuoi documenti e ti guida nella cittadinanza italiana.
        </p>
        <div class="cta-buttons">
          <a href="#" class="btn btn-primary">
            <Fragment set:html={appleSvg} />
            App Store
          </a>
          <a href="#" class="btn btn-primary">
            <Fragment set:html={androidSvg} />
            Google Play
          </a>
          <a href="#features" class="btn btn-secondary">Scopri di più →</a>
        </div>
      </div>
      <div class="hero-image">
        <div class="phone-mockup">
          <div class="phone-frame">
            <div class="phone-screen">
              <div class="app-preview"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-decoration"></div>
  </section>

  <section id="features" class="features">
    <div class="container">
      <h2 class="section-title">Tutto quello che ti serve</h2>
      <div class="features-grid">
        {features.map((f) => (
          <FeatureCard icon={f.icon} title={f.title} description={f.description} />
        ))}
      </div>
    </div>
  </section>

  <section class="how-it-works">
    <div class="container">
      <h2 class="section-title">Come funziona</h2>
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Aggiungi i tuoi documenti</h3>
          <p>Inserisci passaporto, carta d'identità e altri documenti con le loro date di scadenza.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>Ricevi notifiche</h3>
          <p>Vieni avvisato automaticamente prima di ogni scadenza, senza doverci pensare.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>Esplora i servizi</h3>
          <p>Accedi a guide complete per cittadinanza e servizi comunali sempre aggiornati.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Inizia oggi a semplificare la tua vita amministrativa</h2>
        <p>Unisciti a centinaia di utenti che hanno già scelto Civico per gestire documenti e cittadinanza.</p>
        <div class="cta-buttons">
          <a href="#" class="btn btn-primary btn-large">
            <Fragment set:html={appleSvg} />
            App Store
          </a>
          <a href="#" class="btn btn-primary btn-large">
            <Fragment set:html={androidSvg} />
            Google Play
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
